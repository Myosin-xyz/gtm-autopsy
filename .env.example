# Copy to .env.local. With nothing set, the app runs in deterministic mock mode.

# Hivemind API — enables live persona calls AND lead capture + cache/rate-limit.
# The lead hook posts to {BASE_URL}/api/v1/leads and /api/v1/autopsy/cache.
# HIVEMIND_API_KEY=hm_k_xxxxxxxxxxxxxxxxxxxxxxxx
# HIVEMIND_API_BASE_URL=https://staging-hivemind.example.com

# Cloudflare Turnstile (bot gate on the email submit). Unset → gate not enforced.
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# PostHog analytics (top-of-funnel events). Unset → no events.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Hivemind app origin for the unlock-CTA signup deep-link (unset → https://myosin.xyz)
# NEXT_PUBLIC_HIVEMIND_APP_URL=https://staging-app.myosin.xyz
